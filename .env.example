# Telegram Bot Token (from @BotFather) — used for sending messages to channels
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Login Widget 2.0 / OpenID Connect (from @BotFather -> Login Widget)
TELEGRAM_CLIENT_ID=your_client_id
TELEGRAM_CLIENT_SECRET=your_client_secret

# Public domain (used for OIDC redirect_uri and nginx)
DOMAIN=leg-api-postbacks.click

# PostgreSQL (local dev / migrate)
DATABASE_URL=postgres://legends-leads-usr:your_password@localhost:5432/legends-leads-db

# PostgreSQL (docker-compose overrides DATABASE_URL for containers)
POSTGRES_USER=legends-leads-usr
POSTGRES_PASSWORD=your_password
POSTGRES_DB=legends-leads-db
POSTGRES_PORT=5432

# JWT secret for admin sessions (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-random-string

# Super admin Telegram ID
SUPER_ADMIN_TG_ID=6730949764

# App port on host (bound to 127.0.0.1 only, nginx proxies from 443)
APP_PORT=3000
PORT=3000

# NODE_ENV is set by docker-compose / npm scripts — do not put here
